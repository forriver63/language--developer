DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# 限流（可选，没配就不限）
# 在 Vercel 集成 Upstash Redis 后会自动注入 KV_REST_API_URL / KV_REST_API_TOKEN
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# 自定义阈值（可选）
RATE_PER_IP_LIMIT=30
RATE_PER_IP_WINDOW=1 h
RATE_GLOBAL_LIMIT=800
RATE_GLOBAL_WINDOW=1 d

# 前端展示（VITE_ 前缀会编译进客户端）
# 备案号下来后填写，会自动显示在页面 footer
VITE_ICP_NUMBER=
# 分享卡片底部显示的域名
VITE_SITE_DOMAIN=xianyingqi.com

